# ==============================================================================
# PROYECTO 11 - PLATAFORMA DE GESTIÓN DE INCIDENTES
# ARCHIVO DE CONFIGURACIÓN DE EJEMPLO (.env.example)
# Instrucciones: Copiar este archivo como '.env', completar los datos y 
# NUNCA subir el '.env' real al repositorio.
# ==============================================================================

# --- DATABASE CONFIGURATION (PostgreSQL + TimescaleDB) ---
# Si corres NestJS localmente (npm run start:dev): usar 'localhost'
# Si corres NestJS dentro de Docker: usar 'database' (nombre del servicio)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=proyecto11
DB_SCHEMA=public

# --- REDIS CONFIGURATION (Ingesta masiva y Alta Concurrencia) ---
# Host: usar 'localhost' (local) o 'cache' (dentro de Docker)
REDIS_HOST=localhost
REDIS_PORT=6379

# --- APPLICATION CONFIGURATION ---
PORT=3001
NODE_ENV=development

# --- INTEGRACIÓN ECOSISTEMA (Proyecto 12 - Seguridad Zero Trust) ---
# URL base para la validación de tokens provistos por el Proyecto 12
P12_ISSUER="https://underarm-those-stardust.ngrok-free.dev/realms/sistema-centralizado"
P12_JWKS_URI="https://underarm-those-stardust.ngrok-free.dev/realms/sistema-centralizado/protocol/openid-connect/certs"
P12_CLIENT_ID="app-11"

# --- LLAVES ZERO TRUST (Sistemas Externos) ---
API_KEY_P01=auth_p01_secret
API_KEY_P03=auth_p03_secret
API_KEY_P04=auth_p04_secret
API_KEY_P05=auth_p05_secret
API_KEY_P06=auth_p06_secret
API_KEY_P07=auth_p07_secret
API_KEY_P08=auth_p08_secret
API_KEY_P09=auth_p09_secret
API_KEY_P10=auth_p10_secret
API_KEY_P12=auth_p12_secret
# UUID del Sistema Automático para auditoría (Usado cuando no hay un humano)
SISTEMA_AUTOMATICO_UUID=00000000-0000-0000-0000-000000000001

# --- INTEGRACIÓN PROYECTO 6 (Notificaciones) ---
# Outbound: conectores Email (asignación) y Móvil/SMS (SLA vencido)
P6_NOTIFICACIONES_URL=https://ucn-agil-notificaciones.up.railway.app/notifications/send
API_KEY_PROYECTO_11=6KqBvZyXpJ5mWkR8tHsUdC2eAoF3LiG7
# Destinatarios por defecto cuando no se envían en el request (desarrollo local)
P6_DEFAULT_EMAIL=operador@ejemplo.com
P6_DEFAULT_TELEFONO=+56912345678

# --- CREDENCIALES NUBE (NEON & UPSTASH) ---
# Si estas variables están presentes, el sistema se conectará a la nube.
# Si están comentadas o vacías, caerá en el comportamiento "localhost" clásico.
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# REDIS_URL=rediss://default:pass@host:port

# ==============================================================================
# NOTAS SENIOR PARA EL EQUIPO:
# 1. Ejecutar 'docker-compose up -d' antes de iniciar el backend.
# 2. Las credenciales de DB deben coincidir con las del docker-compose.yml.
# 3. La extensión TimescaleDB se activa automáticamente por la imagen docker.
# ==============================================================================