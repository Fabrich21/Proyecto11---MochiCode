{
  "name": "proyecto11--mochicode",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo fullstack con Next.js y NestJS",
  "scripts": {
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run start:dev -w backend",
    "build": "npm run build -w frontend && npm run build -w backend",
    "lint": "npm run lint -w frontend && npm run lint -w backend",
    "migration:run": "node -r ts-node/register apps/backend/scripts/migration-runner.ts run",
    "migration:revert": "node -r ts-node/register apps/backend/scripts/migration-runner.ts revert"
  },
  "workspaces": [
    "apps/frontend",
    "apps/backend"
  ],
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
